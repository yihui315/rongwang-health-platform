# ===========================
# 荣旺健康 + GEOFlow 环境变量
# ===========================

# --- Next.js ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- 分析与广告追踪 ---
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=rongwang.health
NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id

# --- 邮件营销（二选一） ---
# Mailchimp
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_LIST_ID=your-mailchimp-list-id
# Brevo (Sendinblue)
# BREVO_API_KEY=your-brevo-api-key
# BREVO_LIST_ID=your-brevo-list-id

# --- GEOFlow API 桥接 ---
GEOFLOW_API_URL=http://localhost:18080/api/v1
GEOFLOW_API_TOKEN=your-geoflow-api-token
GEOFLOW_WEBHOOK_SECRET=your-webhook-secret

# --- GEOFlow 后台 ---
GEO_DB_PASSWORD=geo_password_secure_change_me
GEO_APP_SECRET=replace-with-a-64-char-random-string
GEO_SITE_URL=http://localhost:18080

# --- AI 模型 (在 GEOFlow 后台配置) ---
# 支持 OpenAI 兼容接口: MiniMax / DeepSeek / OpenAI / Ollama
# AI_API_KEY=your-ai-api-key
# AI_API_BASE=https://api.minimax.chat/v1
