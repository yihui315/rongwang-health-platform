COPILOT_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
MINIMAX_API_KEY=

# Package 1 foundation: Prisma on top of Postgres / Supabase Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rongwang?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/rongwang?schema=public

# Redis rate limiting (optional)
# If these are empty, the app falls back to in-memory rate limiting for local development.
# Prefer Upstash/Vercel Redis REST credentials in production so limits work across instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_REST_URL=
REDIS_REST_TOKEN=
REDIS_URL=
REDIS_TOKEN=

# Future AI provider rollout
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
AI_PROVIDER=openai
AI_MODEL=gpt-5.4
AI_PROMPT_VERSION=v1

# Feature flags for safe rollout
# Defaults are true when omitted.
FEATURE_AI_PROVIDER=true
FEATURE_DB_RECOMMENDATION_RULES=true
FEATURE_ANALYTICS_PERSISTENCE=true
FEATURE_MARKETING_AUTOMATION=true
FEATURE_MARKETING_AUTOPILOT=true
FEATURE_MARKETING_CONTENT_AI=false
FEATURE_MARKETING_EMAIL_AI=false
FEATURE_MARKETING_LANDING_AI=false
MARKETING_CONTENT_RATE_LIMIT=12
MARKETING_CONTENT_RATE_WINDOW_MS=600000
MARKETING_AUTOMATION_RATE_LIMIT=12
MARKETING_AUTOMATION_RATE_WINDOW_MS=600000
MARKETING_AUTOPILOT_RATE_LIMIT=12
MARKETING_AUTOPILOT_RATE_WINDOW_MS=600000
MARKETING_EMAIL_RATE_LIMIT=12
MARKETING_EMAIL_RATE_WINDOW_MS=600000
MARKETING_LANDING_RATE_LIMIT=12
MARKETING_LANDING_RATE_WINDOW_MS=600000
MARKETING_AUTO_PUBLISH_GEOFLOW=false
MARKETING_AUTOPILOT_EXECUTE=false
