page {
  background: #f4f7f5;
  color: #12312c;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(15, 118, 110, 0.08);
}

.eyebrow {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.title {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.body {
  margin-top: 18rpx;
  color: #52635f;
  font-size: 28rpx;
  line-height: 1.7;
}

.button-primary,
.button-secondary {
  margin-top: 24rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.button-primary {
  background: #0f766e;
  color: #ffffff;
}

.button-secondary {
  background: #e7f5f1;
  color: #0f766e;
}
