<view class="page">
  <view class="card">
    <view class="eyebrow">PRODUCT MAP</view>
    <view class="title">评估后的方案参考</view>
    <view class="body">商品只作为健康教育后的方向参考，建议先完成 AI 评估。</view>
    <button class="button-primary" bindtap="goAssessment">立即开始 AI 评估</button>
  </view>

  <view wx:if="{{loading}}" class="card body">加载方案中...</view>
  <view wx:if="{{error}}" class="card body">{{error}}</view>

  <view wx:for="{{products}}" wx:key="slug" class="card product-card" bindtap="openDetail" data-slug="{{item.slug}}">
    <view class="eyebrow">{{item.category}}</view>
    <view class="product-name">{{item.name}}</view>
    <view class="body">{{item.tagline}}</view>
    <view class="price">HK${{item.memberPrice || item.price}}</view>
  </view>
</view>
