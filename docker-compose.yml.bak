name: rongwang-health

services:
  # ========== 前台: 荣旺健康 Next.js ==========
  nextjs:
    build:
      context: .
      dockerfile: Dockerfile
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=production
      - GEOFLOW_API_URL=http://geoflow:18080/api/v1
      - GEOFLOW_API_TOKEN=${GEOFLOW_API_TOKEN}
      - GEOFLOW_WEBHOOK_SECRET=${GEOFLOW_WEBHOOK_SECRET}
      - NEXT_PUBLIC_SUPABASE_URL=${NEXT_PUBLIC_SUPABASE_URL}
      - NEXT_PUBLIC_SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY}
      - STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
      - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY}
      - NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL:-http://localhost:3000}
    depends_on:
      - geoflow
    restart: unless-stopped
    networks:
      - rongwang-net

  # ========== 后台: GEOFlow 内容引擎 ==========
  geoflow:
    build:
      context: ./geoflow
      dockerfile: docker/Dockerfile
    ports:
      - "18080:18080"
    environment:
      - HOST_PORT=18080
      - DB_DRIVER=pgsql
      - DB_HOST=postgres
      - DB_PORT=5432
      - DB_NAME=geo_system
      - DB_USER=geo_user
      - DB_PASSWORD=${GEO_DB_PASSWORD:-geo_password_secure}
      - DB_EXPOSE_PORT=15432
      - CRON_INTERVAL=60
      - APP_SECRET_KEY=${GEO_APP_SECRET:-replace-with-long-random-secret}
      - SITE_URL=${GEO_SITE_URL:-http://localhost:18080}
      - TZ=Asia/Shanghai
      - REQUIRE_STRONG_APP_SECRET=false
    depends_on:
      postgres:
        condition: service_healthy
    restart: unless-stopped
    networks:
      - rongwang-net
    volumes:
      - geoflow-data:/app/data

  # ========== GEOFlow Scheduler + Worker ==========
  geoflow-scheduler:
    build:
      context: ./geoflow
      dockerfile: docker/Dockerfile
    command: /app/docker/scheduler.sh
    environment:
      - DB_DRIVER=pgsql
      - DB_HOST=postgres
      - DB_PORT=5432
      - DB_NAME=geo_system
      - DB_USER=geo_user
      - DB_PASSWORD=${GEO_DB_PASSWORD:-geo_password_secure}
      - CRON_INTERVAL=60
      - APP_SECRET_KEY=${GEO_APP_SECRET:-replace-with-long-random-secret}
      - TZ=Asia/Shanghai
    depends_on:
      postgres:
        condition: service_healthy
    restart: unless-stopped
    networks:
      - rongwang-net
    volumes:
      - geoflow-data:/app/data

  # ========== PostgreSQL ==========
  postgres:
    image: postgres:16-alpine
    environment:
      - POSTGRES_DB=geo_system
      - POSTGRES_USER=geo_user
      - POSTGRES_PASSWORD=${GEO_DB_PASSWORD:-geo_password_secure}
    ports:
      - "15432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U geo_user -d geo_system"]
      interval: 5s
      timeout: 5s
      retries: 5
    restart: unless-stopped
    networks:
      - rongwang-net

  # ========== Caddy 反向代理 ==========
  caddy:
    image: caddy:2-alpine
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile
      - caddy-data:/data
      - caddy-config:/config
    depends_on:
      - nextjs
      - geoflow
    restart: unless-stopped
    networks:
      - rongwang-net

volumes:
  postgres-data:
  geoflow-data:
  caddy-data:
  caddy-config:

networks:
  rongwang-net:
    driver: bridge
